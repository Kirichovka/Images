#!/usr/bin/env sh

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File "./scripts/validate-images.ps1"
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "./scripts/validate-images.ps1"
fi

echo "PowerShell is required to validate image sizes before push." >&2
exit 1
